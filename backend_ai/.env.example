# 이 파일을 복사해서 .env 로 저장한 뒤 값을 채우세요.
#   Windows: copy .env.example .env
#   macOS/Linux: cp .env.example .env
#
# .env 는 .gitignore 에 포함되어 Git에 올라가지 않습니다.
# 다른 PC·서버에서는 각각 .env 를 만들거나, 아래 이름의 환경 변수를 설정하면 됩니다.

# Groq (필수 권장) — https://console.groq.com/
GROQ_API_KEY=

# Google Gemini 폴백용 — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# 선택: 예전 이름으로 Groq 키만 쓰는 경우 (GROQ_API_KEY 가 비어 있을 때만 사용)
# capstone=
